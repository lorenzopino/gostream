# Template Dockerfile: Jellyfin (LinuxServer) + GoStream + Python scripts.
# Build context must contain a ./src folder with this repo's contents.

FROM golang:1.24-bookworm AS build

RUN apt-get update \
    && apt-get install -y --no-install-recommends \
      build-essential \
      pkg-config \
      libfuse3-dev \
      ca-certificates \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /src

COPY ./src/go.mod ./src/go.sum ./
COPY ./src/internal/anacrolix-torrent-v1.55/go.mod ./internal/anacrolix-torrent-v1.55/go.mod
COPY ./src/internal/anacrolix-torrent-v1.55/go.sum ./internal/anacrolix-torrent-v1.55/go.sum
RUN go mod download

COPY ./src/. ./

ARG APP_VERSION=dev

RUN CGO_ENABLED=1 GOOS=linux \
    go build -pgo=auto -ldflags "-X main.AppVersion=${APP_VERSION}" -o /out/gostream .


FROM lscr.io/linuxserver/jellyfin:latest

RUN apt-get update \
    && apt-get install -y --no-install-recommends \
      ca-certificates \
      curl \
      fuse3 \
      iptables \
      python3 \
      python3-venv \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

COPY ./src/requirements.txt /tmp/requirements.txt
RUN python3 -m venv /app/venv \
    && /app/venv/bin/pip install --no-cache-dir --upgrade pip \
    && /app/venv/bin/pip install --no-cache-dir -r /tmp/requirements.txt \
    && rm -f /tmp/requirements.txt

COPY --from=build /out/gostream /usr/local/bin/gostream
COPY ./src/scripts /app/scripts

ENV PATH=/app/venv/bin:$PATH

# Windows bind mounts can drop execute bits, so bake the custom hook scripts in.
COPY ./custom-services /custom-services.d
COPY ./custom-cont-init /custom-cont-init.d
RUN chmod +x /custom-services.d/* /custom-cont-init.d/* || true
